generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  businessType  String
  parentId      String?
  parent        Company? @relation("CompanyHierarchy", fields: [parentId], references: [id])
  children      Company[] @relation("CompanyHierarchy")
  ceoId         String?
  users         User[]
  departments   Department[]
  products      Product[]
  clients       Client[]
  suppliers     Supplier[]
  inventories   Inventory[]
  inventoryMovements InventoryMovement[]
  purchaseOrders PurchaseOrder[]
  salesOrders   SalesOrder[]
  quotations    Quotation[]
  manufacturingOrders ManufacturingOrder[]
  transactions  Transaction[]
  invoices      Invoice[]
  payments      Payment[]
  stockAllocations StockAllocation[]
  expenses      Expense[]
  productionCosts ProductionCost[]
  territories   Territory[]
  commissionRules CommissionRule[]
  distributorInventories DistributorInventory[]
  commissions   Commission[]
  payouts       Payout[]
  auditLogs     AuditLog[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  role          Role
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  salesOrders   SalesOrder[] @relation("SalesAgentOrders")
  quotations    Quotation[] @relation("QuotationAgent")
  territoryId   String?
  territory     Territory? @relation(fields: [territoryId], references: [id])
  rank          String?
  monthlyVolume Decimal  @default(0)
  sponsorId     String?
  sponsor       User?    @relation("SponsorRelation", fields: [sponsorId], references: [id])
  sponsoredUsers User[]  @relation("SponsorRelation")
  distributorInventory DistributorInventory[]
  commissions   Commission[]
  payouts       Payout[]
  approvedPayouts Payout[] @relation("ApprovedPayout")
  auditLogs     AuditLog[]
  distributorOrders SalesOrder[] @relation("DistributorOrder")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  MANAGER
  SALES_AGENT
  DEALER
  BRAND_PARTNER
  CLIENT
  RESELLER
  DISTRIBUTOR
  TERRITORY_PARTNER
}

model Department {
  id          String   @id @default(cuid())
  name        String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  users       User[]
  createdAt   DateTime @default(now())
}

model Product {
  id              String   @id @default(cuid())
  code            String
  name            String
  description     String?
  category        String
  source          String
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  unit            String
  costPrice       Decimal
  sellingPrice    Decimal
  currentStock    Int      @default(0)
  minimumStock    Int      @default(0)
  maximumStock    Int      @default(0)
  warehouseLocation String?
  status          String   @default("active")
  inventory       Inventory[]
  inventoryMovements InventoryMovement[]
  salesOrderItems SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  manufacturingOrders ManufacturingOrder[]
  rawMaterialsUsed RawMaterialUsed[]
  stockAllocations StockAllocation[]
  productionCosts ProductionCost[]
  quotationItems  QuotationItem[]
  commissionRules CommissionRule[]
  distributorInventories DistributorInventory[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Client {
  id            String   @id @default(cuid())
  code          String
  name          String
  email         String?
  phone         String?
  address       String?
  type          String
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  salesOrders   SalesOrder[]
  quotations    Quotation[]
  invoices      Invoice[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Supplier {
  id            String   @id @default(cuid())
  code          String
  name          String
  email         String?
  phone         String?
  address       String?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  purchaseOrders PurchaseOrder[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Inventory {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  warehouse     String
  quantity      Int      @default(0)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([productId, warehouse, companyId])
}

model InventoryMovement {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  type          String
  quantity      Int
  referenceId   String?
  notes         String?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  orderNumber   String
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  status        String   @default("pending")
  totalAmount   Decimal
  expectedDate  DateTime?
  receivedDate  DateTime?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  items         PurchaseOrderItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Int
  unitCost        Decimal
  totalCost       Decimal
}

model SalesOrder {
  id            String   @id @default(cuid())
  orderNumber   String
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  salesAgentId  String
  salesAgent    User     @relation("SalesAgentOrders", fields: [salesAgentId], references: [id])
  status        String   @default("pending")
  totalAmount   Decimal
  discount      Decimal  @default(0)
  commission    Decimal  @default(0)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  items         SalesOrderItem[]
  distributorId String?
  distributor   User?    @relation("DistributorOrder", fields: [distributorId], references: [id])
  territoryId   String?
  territory     Territory? @relation(fields: [territoryId], references: [id])
  commissionCalculated Boolean @default(false)
  commissions   Commission[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SalesOrderItem {
  id            String   @id @default(cuid())
  salesOrderId  String
  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int
  costPrice     Decimal  @default(0)
  sellingPrice  Decimal
  discount      Decimal  @default(0)
  total         Decimal
}

model Quotation {
  id            String   @id @default(cuid())
  quoteNumber   String
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  salesAgentId  String
  salesAgent    User     @relation("QuotationAgent", fields: [salesAgentId], references: [id])
  status        String   @default("draft")
  validUntil    DateTime
  totalAmount   Decimal
  notes         String?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  items         QuotationItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model QuotationItem {
  id            String   @id @default(cuid())
  quotationId   String
  quotation     Quotation @relation(fields: [quotationId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int
  unitPrice     Decimal
  total         Decimal
}

model ManufacturingOrder {
  id            String   @id @default(cuid())
  orderNumber   String
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int
  status        String   @default("pending")
  startDate     DateTime?
  completionDate DateTime?
  totalCost     Decimal?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  materials     RawMaterialUsed[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RawMaterialUsed {
  id                    String   @id @default(cuid())
  manufacturingOrderId  String
  manufacturingOrder    ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id])
  productId             String
  product               Product  @relation(fields: [productId], references: [id])
  quantity              Int
  unitCost              Decimal
  totalCost             Decimal
}

model Transaction {
  id            String   @id @default(cuid())
  type          String
  category      String
  amount        Decimal
  description   String?
  referenceId   String?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  salesOrderId  String?
  amount        Decimal
  tax           Decimal  @default(0)
  total         Decimal
  status        String   @default("pending")
  dueDate       DateTime
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  payments      Payment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  amount        Decimal
  method        String
  reference     String?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
}

model StockAllocation {
  id                String   @id @default(cuid())
  productId         String
  product           Product  @relation(fields: [productId], references: [id])
  availableQuantity Int
  reservedQuantity  Int      @default(0)
  approvedQuantity  Int?
  approvedById      String?
  approvalDate      DateTime?
  weekStarting      DateTime
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Expense {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  category      String
  subcategory   String?
  amount        Decimal
  description   String?
  date          DateTime @default(now())
  referenceId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProductionCost {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  type          String
  category      String?
  amount        Decimal
  quantity      Int?
  unit          String?
  description   String?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Territory {
  id            String   @id @default(cuid())
  name          String
  type          String
  parentId      String?
  parent        Territory? @relation("TerritoryHierarchy", fields: [parentId], references: [id])
  children      Territory[] @relation("TerritoryHierarchy")
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  users         User[]
  salesOrders   SalesOrder[]
  commissionRules CommissionRule[]
  commissions   Commission[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CommissionRule {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  productId     String?
  product       Product? @relation(fields: [productId], references: [id])
  userRole      String
  territoryId   String?
  territory     Territory? @relation(fields: [territoryId], references: [id])
  type          String
  amount        Decimal
  overrideUp    Boolean  @default(false)
  overridePercent Decimal?
  status        String   @default("active")
  commissions   Commission[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DistributorInventory {
  id            String   @id @default(cuid())
  distributorId String
  distributor   User     @relation(fields: [distributorId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int      @default(0)
  available     Int      @default(0)
  reserved      Int      @default(0)
  costPrice     Decimal
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([distributorId, productId, companyId])
}

model Commission {
  id            String   @id @default(cuid())
  orderId       String
  order         SalesOrder @relation(fields: [orderId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  type          String
  amount        Decimal
  ruleId        String?
  rule          CommissionRule? @relation(fields: [ruleId], references: [id])
  territoryId   String?
  territory     Territory? @relation(fields: [territoryId], references: [id])
  status        String   @default("pending")
  payoutId      String?
  payout        Payout?  @relation(fields: [payoutId], references: [id])
  payoutItems   PayoutItem[]
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
}

model Payout {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  weekStarting  DateTime
  weekEnding    DateTime
  totalAmount   Decimal
  status        String   @default("pending")
  paymentMethod String?
  paymentReference String?
  approvedById  String?
  approvedBy    User?    @relation("ApprovedPayout", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  releasedAt    DateTime?
  paidAt        DateTime?
  items         PayoutItem[]
  commissions   Commission[]
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PayoutItem {
  id            String   @id @default(cuid())
  payoutId      String
  payout        Payout   @relation(fields: [payoutId], references: [id])
  commissionId  String
  commission    Commission @relation(fields: [commissionId], references: [id])
  type          String
  amount        Decimal
  description   String?
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  action        String
  entity        String
  entityId      String?
  details       Json?
  ipAddress     String?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
}
